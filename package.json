{
  "name": "lingodeck",
  "private": true,
  "version": "0.1.0",
  "description": "LingoDeck - Personal Vocabulary Learning System",
  "workspaces": [
    "apps/web",
    "apps/server"
  ],
  "scripts": {
    "dev": "concurrently -k -n WEB,API -c blue,green \"npm run dev -w apps/web\" \"npm run dev -w apps/server\"",
    "dev:web": "npm run dev -w apps/web",
    "dev:server": "npm run dev -w apps/server",
    "build": "npm run build -w apps/server && npm run build -w apps/web",
    "build:web": "npm run build -w apps/web",
    "build:server": "npm run build -w apps/server",
    "db:migrate": "npm run db:migrate -w apps/server",
    "db:seed": "npm run db:seed -w apps/server",
    "db:studio": "npm run db:studio -w apps/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
