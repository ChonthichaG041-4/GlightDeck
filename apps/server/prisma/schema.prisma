// GlightDeck - Prisma schema
// Personal Vocabulary Learning System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Enums ----------

enum Level {
  A1
  A2
  B1
  B2
  C1
  C2
}

enum WordType {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
  IDIOM
  SLANG
  PHRASE
  PREPOSITION
  CONJUNCTION
  PRONOUN
  OTHER
}

enum WordStatus {
  NEW
  LEARNING
  REVIEW
  MASTERED
}

enum QuizType {
  MULTIPLE_CHOICE
  MATCHING
  MEANING
  SENTENCE
  LISTENING
}

enum ReviewRating {
  AGAIN
  HARD
  GOOD
  EASY
}

enum ArticleVisibility {
  PRIVATE
  PUBLIC
  UNLISTED
}

// ---------- Core models ----------

model User {
  id          String   @id @default(cuid())
  clerkId     String   @unique
  email       String   @unique
  name        String?
  avatarUrl   String?
  currentStreak Int    @default(0)
  longestStreak Int    @default(0)
  lastActiveAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  words         Word[]
  collections   Collection[]
  tags          Tag[]
  articles      Article[]
  sentences     SentenceBookmark[]
  quizAttempts  QuizAttempt[]
  reviewLogs    ReviewLog[]
  achievements  UserAchievement[]
  dailyProgress DailyProgress[]
  streakLogs    StreakLog[]

  highlights        Highlight[]
  notes             Note[]
  readingBookmarks  ReadingBookmark[]
  articleLikes      ArticleLike[]
  articleAttempts   ArticleAttempt[]
  articleRatings    ArticleRating[]
}

model Collection {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?  @default("📚")
  color       String?  @default("#6366f1")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  words Word[]

  @@index([userId])
}

model Tag {
  id        String   @id @default(cuid())
  name      String
  color     String?  @default("#a855f7")
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  words WordTag[]

  @@unique([userId, name])
  @@index([userId])
}

model Word {
  id        String     @id @default(cuid())
  headword  String
  sourceLang String    @default("en") // language of the headword
  meaning   String    // primary/back-compat translation
  ipa       String?
  type      WordType   @default(OTHER)
  level     Level      @default(A1)
  example   String?
  exampleTranslate String?
  synonym   String?
  opposite  String?
  frequency Int        @default(3) // 1-5 stars
  image     String?    @default("📘") // emoji or URL
  audioUrl  String?
  note      String?    // personal note (e.g. "this comes up a lot in TOEIC") - set from Reading Workspace's Save Vocabulary dialog
  status    WordStatus @default(NEW)
  favorite  Boolean    @default(false)

  // Spaced Repetition (SM-2 style, Anki-like)
  easeFactor   Float    @default(2.5)
  intervalDays Float    @default(0)
  repetitions  Int      @default(0)
  lapses       Int      @default(0) // wrong-answer count, drives "Smart Review"
  dueDate      DateTime @default(now())
  lastReviewedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  collectionId String?
  collection   Collection? @relation(fields: [collectionId], references: [id], onDelete: SetNull)

  tags WordTag[]
  translations WordTranslation[]
  reviewLogs ReviewLog[]

  relationsFrom WordRelation[] @relation("relFrom")
  relationsTo   WordRelation[] @relation("relTo")

  sentences SentenceBookmark[]

  @@index([userId])
  @@index([collectionId])
  @@index([userId, status])
  @@index([userId, dueDate])
}

model WordTag {
  wordId String
  tagId  String
  word   Word @relation(fields: [wordId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([wordId, tagId])
}

// Multiple target-language translations per word (e.g. th, ja, ko...).
// `Word.meaning` stays as the primary/back-compat translation for existing UI.
model WordTranslation {
  id        String   @id @default(cuid())
  lang      String   // ISO-ish language code: th, en, ja, ko, zh, ...
  text      String
  createdAt DateTime @default(now())

  wordId String
  word   Word   @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([wordId, lang])
}

// Word relationship "mindmap" (happy -> joy -> cheerful -> ...)
model WordRelation {
  id     String @id @default(cuid())
  fromId String
  toId   String
  label  String? @default("related") // e.g. synonym, chain

  from Word @relation("relFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to   Word @relation("relTo", fields: [toId], references: [id], onDelete: Cascade)

  @@unique([fromId, toId])
}

// Anki-style SM-2 review history, one row per flashcard review event
model ReviewLog {
  id        String       @id @default(cuid())
  rating    ReviewRating
  intervalDays Float
  easeFactor   Float
  reviewedAt DateTime    @default(now())

  wordId String
  word   Word   @relation(fields: [wordId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, reviewedAt])
  @@index([wordId])
}

model Article {
  id        String   @id @default(cuid())
  title     String
  category  String   @default("Reading") // Harry Potter, Game Articles, News, Novel...
  content   String   @db.Text
  source    String?
  createdAt DateTime @default(now())

  // AI-generated / Create Mode reading-passage fields (all optional - the older
  // paste-your-own-text "My Articles" flow leaves these null).
  translation   String?           @db.Text
  questionsJson Json?
  examMode      String?
  cefrLevel     String?
  testMode      String?
  visibility    ArticleVisibility @default(PRIVATE)
  viewCount     Int               @default(0)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  highlights       Highlight[]
  notes            Note[]
  readingBookmarks ReadingBookmark[]
  likes            ArticleLike[]
  attempts         ArticleAttempt[]
  ratings          ArticleRating[]

  @@index([userId])
  @@index([visibility])
}

// A user's saved text-selection highlight within a passage. Offsets are plain
// character offsets into Article.content (client computes them from the
// rendered text, since the passage is plain text without any markup).
model Highlight {
  id          String   @id @default(cuid())
  text        String
  startOffset Int
  endOffset   Int
  color       String   @default("#fde68a")
  createdAt   DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, userId])
}

// A free-form note attached to a spot in the passage (from the floating
// selection toolbar's "Add Note").
model Note {
  id           String   @id @default(cuid())
  text         String
  anchorText   String?
  anchorOffset Int?
  createdAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId, userId])
}

// Named ReadingBookmark (not just "Bookmark") to avoid clashing with any
// future generic bookmark concept - this one is specifically a saved spot
// within a Reading passage.
model ReadingBookmark {
  id           String   @id @default(cuid())
  anchorText   String?
  anchorOffset Int?
  createdAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId, anchorOffset])
}

model ArticleLike {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
}

model ArticleAttempt {
  id        String   @id @default(cuid())
  score     Int
  total     Int
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@index([articleId])
}

model ArticleRating {
  id        String   @id @default(cuid())
  rating    Int
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
}

model SentenceBookmark {
  id         String   @id @default(cuid())
  text       String
  translation String?
  createdAt  DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  wordId String?
  word   Word?  @relation(fields: [wordId], references: [id], onDelete: SetNull)

  @@index([userId])
}

model QuizAttempt {
  id        String   @id @default(cuid())
  type      QuizType
  score     Int
  total     Int
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model DailyProgress {
  id     String   @id @default(cuid())
  date   DateTime @db.Date

  reviewCount   Int @default(0)
  listeningCount Int @default(0)
  meaningCount   Int @default(0)
  sentenceCount Int @default(0)
  newWordsCount Int @default(0)
  articlesRead  Int @default(0)

  reviewTarget   Int @default(20)
  listeningTarget Int @default(10)
  meaningTarget   Int @default(10)
  sentenceTarget Int @default(5)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model StreakLog {
  id   String   @id @default(cuid())
  date DateTime @db.Date

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

// Reference dictionary data imported offline from Kaikki.org's Wiktionary
// extract (see scripts/import-kaikki.ts). Powers the Reading Workspace's
// double-click dictionary popup with real IPA/audio/synonyms/antonyms and,
// crucially, genuine Thai translations straight from Wiktionary - so the
// popup no longer depends entirely on Gemini for every field. Global
// reference data shared by all users, not owned by any one User.
model DictionaryEntry {
  id           String   @id @default(cuid())
  word         String   // lowercase headword, e.g. "overwhelming"
  pos          String   // part of speech as given by Wiktionary, e.g. "adj", "noun", "verb"
  ipa          String?
  audioUrl     String?
  senses       Json     // [{ gloss: string, examples: string[], tags: string[] }]
  synonyms     String[]
  antonyms     String[]
  translations Json     // [{ lang: string, word: string }] - filtered to languages GlightDeck supports
  sourceRev    String?  // Kaikki dump date (e.g. "2026-06-28"), for tracking re-imports
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([word, pos])
  @@index([word])
}

model Achievement {
  id          String @id @default(cuid())
  key         String @unique // e.g. STREAK_7, STREAK_30, WORDS_100, WORDS_500
  title       String
  description String
  icon        String @default("🔥")

  users UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  unlockedAt    DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
}
